### CELL 3 — Extract sheet3.zip
```python
import zipfile, os

with zipfile.ZipFile(
        '/content/drive/MyDrive/MyDataset/2026/2026/sheet3.zip', 'r') as z:
    z.extractall('/content/')

assert os.path.exists('/content/sheet3/dataset.py'), \
    "dataset.py not found — check zip path"
print("✓ /content/sheet3/dataset.py ready")
```

### CELL 4 — Extract dataset splits
```python
import zipfile, os

BASE = '/content/drive/MyDrive/MyDataset/2026/2026'
DEST = '/content/data/MyDataset'
os.makedirs(DEST, exist_ok=True)

for name in ['train.zip', 'validation.zip', 'test.zip']:
    zpath = f'{BASE}/{name}'
    if os.path.exists(zpath):
        print(f'Extracting {name} ...')
        with zipfile.ZipFile(zpath, 'r') as z:
            z.extractall(DEST)
        print(f' FOUND')
    else:
        print(f'  NOT FOUND: {zpath}')

# Verify
for split in ['train', 'validation', 'test']:
    ok = os.path.exists(f'{DEST}/{split}/labels.csv')
    print(f"{'✓' if ok else '✗'} {split}/labels.csv")
```

### CELL 5 — Upload calibration.py
Upload manually. 
It lands at `/content/calibration.py`.

### CELL 6 — Confirm checkpoint task keys
```python
import torch, os

CKPT_DIR = '/content/drive/MyDrive/MyDataset/sheet3_results/checkpoints'
for fname in sorted(os.listdir(CKPT_DIR)):
    if fname.endswith('.pt'):
        state = torch.load(f'{CKPT_DIR}/{fname}', map_location='cpu')
        print(f"{fname:35s}  task={state.get('task'):<20s}  "
              f"label_col={state.get('label_column')}")
```

### CELL 7 — Set checkpoint paths (adjust names to match Cell 6 output)
```python
CKPT_DIR = '/content/drive/MyDrive/MyDataset/sheet3_results/checkpoints'
DATA_ROOT = '/content/data/MyDataset'

# Set each to the file whose internal task= matches
CKPT_PEDESTRIAN  = f'{CKPT_DIR}/pedestrain.pt'   # task=pedestrian
CKPT_TRAFFIC     = f'{CKPT_DIR}/traffic_light.pt'   # task=traffic_light
CKPT_VEHICLE     = f'{CKPT_DIR}/vehicle.pt'   # task=vehicle


### CELL 8 — Running all exercises at once
```python
!python /content/calibration.py \
    --data-root  {DATA_ROOT} \
    --checkpoint {CKPT_PEDESTRIAN} {CKPT_TRAFFIC} {CKPT_VEHICLE} \
    --out-dir    /content/outputs \
    --exercises  7.4,7.5,7.6 \
    --batch-size 64
```

